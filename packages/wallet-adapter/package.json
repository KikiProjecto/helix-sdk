{
  "name": "@helix-sdk/wallet-adapter",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --sourcemap",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@helix-sdk/core": "workspace:^",
    "@helix-sdk/jito": "workspace:^",
    "@helix-sdk/fees": "workspace:^",
    "@solana/web3.js": "2.0.0"
  },
  "peerDependencies": {
    "@solana/wallet-adapter-base": "^0.9.23"
  }
}
